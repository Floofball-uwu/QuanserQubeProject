<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="qube" params="prefix">

    <xacro:property name="box_x" value="0.102"/>
    <xacro:property name="box_y" value="0.102"/>
    <xacro:property name="box_z" value="0.102"/>

    <xacro:property name="disk_radius" value="0.025"/>
    <xacro:property name="disk_length" value="0.01"/>

    <xacro:property name="indicator_x" value="0.020"/>
    <xacro:property name="indicator_y" value="0.002"/>
    <xacro:property name="indicator_z" value="0.0015"/>

    <material name="black">
      <color rgba="0.05 0.05 0.05 1"/>
    </material>

    <material name="white">
      <color rgba="1 1 1 1"/>
    </material>

    <material name="red">
      <color rgba="1 0 0 1"/>
    </material>

    <link name="${prefix}base_link"/>

    <link name="${prefix}body_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${box_x} ${box_y} ${box_z}"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <link name="${prefix}disk_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${disk_radius}" length="${disk_length}"/>
        </geometry>
        <material name="red"/>
      </visual>
    </link>

    <link name="${prefix}indicator_link">
      <visual>
        <origin xyz="${disk_radius/2} 0 ${disk_length/2 + indicator_z/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${indicator_x} ${indicator_y} ${indicator_z}"/>
        </geometry>
        <material name="white"/>
      </visual>
    </link>

    <joint name="${prefix}body_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}body_link"/>
      <origin xyz="0 0 ${box_z/2}"/>
    </joint>

    <joint name="${prefix}motor_joint" type="revolute">
      <parent link="${prefix}body_link"/>
      <child link="${prefix}disk_link"/>
      <origin xyz="0 0 ${box_z/2 + disk_length/2}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.5708" upper="1.5708" effort="100" velocity="100"/>
    </joint>

    <joint name="${prefix}indicator_joint" type="fixed">
      <parent link="${prefix}disk_link"/>
      <child link="${prefix}indicator_link"/>
      <origin xyz="0 0 0"/>
    </joint>

  </xacro:macro>
</robot>